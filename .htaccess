RewriteEngine On

# 1. Force non-www + HTTPS (first - most important to avoid loops)
RewriteCond %{HTTP_HOST} ^www\.emmmscakes\.com [NC]
RewriteRule ^(.*)$ https://emmmscakes.com/$1 [L,R=301]

# 2. Force HTTPS (if someone visits with http)
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Hide .html extension (clean URLs)
# Serve .html files when requested without the extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Optional but recommended: Redirect if someone directly accesses .html (cleaner URLs)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1 [R=301,L]